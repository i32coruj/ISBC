SubClassOf(<http://www.pizza.com/ontologies/pizza.owl#SohoPizza> ObjectAllValuesFrom(<http://www.pizza.com/ontologies/pizza.owl#hasTopping> ObjectUnionOf(<http://www.pizza.com/ontologies/pizza.owl#MozzarellaTopping> <http://www.pizza.com/ontologies/pizza.owl#OliveTopping> <http://www.pizza.com/ontologies/pizza.owl#ParmezanTopping> <http://www.pizza.com/ontologies/pizza.owl#TomatoTopping>)))

