EquivalentClasses(<http://www.pizza.com/ontologies/pizza.owl#VegetarianPizza> ObjectIntersectionOf(<http://www.pizza.com/ontologies/pizza.owl#Pizza> ObjectAllValuesFrom(<http://www.pizza.com/ontologies/pizza.owl#hasTopping> ObjectUnionOf(<http://www.pizza.com/ontologies/pizza.owl#CheeseTopping> <http://www.pizza.com/ontologies/pizza.owl#VegetableTopping>))))


